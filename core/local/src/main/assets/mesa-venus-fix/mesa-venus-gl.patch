-   dri2_dpy->driver_name = strdup(disp->Options.Zink ? "zink" : "swrast");
+   {
+      /* Over a wl_shm-only compositor the GPU/dmabuf init adds no EGLConfigs, so
+       * eglInitialize retries with ForceSoftware and clears Options.Zink — which

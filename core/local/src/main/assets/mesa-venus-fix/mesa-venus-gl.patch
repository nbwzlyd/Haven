+      const char *ov = getenv("MESA_LOADER_DRIVER_OVERRIDE");
+      bool want_zink = disp->Options.Zink || (ov && !strcmp(ov, "zink"));
+      dri2_dpy->driver_name = strdup(want_zink ? "zink" : "swrast");

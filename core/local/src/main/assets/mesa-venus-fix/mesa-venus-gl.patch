+   /* The GPU/dmabuf path needs wl_drm or linux-dmabuf, which a pixman/wl_shm-only
+    * compositor doesn't advertise. When it fails, fall back to swrast-init
+    * WITHOUT forcing ForceSoftware: for zink that builds a kopper screen on the
+    * real (venus) GPU and presents over the Vulkan WSI sw path. */
+   if (dri2_initialize_wayland_drm(disp))
+      return EGL_TRUE;
+   return dri2_initialize_wayland_swrast(disp);
